{
  "manifest_version": 3,
  "name": "LinkedIn Profile Analyzer",
  "version": "1.0.0",
  "description": "Extract and analyze LinkedIn profiles with AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js", "deep-scraper.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
