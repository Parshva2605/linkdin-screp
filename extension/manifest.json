{
  "manifest_version": 3,
  "name": "LinkedIn Profile Analyzer",
  "version": "1.0.0",
  "description": "Extract and analyze LinkedIn profiles with AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:11434/*"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js", "deep-scraper.js", "smart-scraper.js", "my-profile-scraper.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["opti/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
